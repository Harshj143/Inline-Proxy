{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-gateway.dev/schemas/policy-v1.json",
  "title": "MCP Security Gateway policy document (schema_version 1)",
  "description": "One policy layer. Layers merge in CLI order: base < connector pack < company override. Reference this schema from YAML/JSON policy files for editor autocomplete.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "const": 1 },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Layer name used in audit attribution and `policy show`. Defaults to the file stem."
    },
    "default_action": {
      "enum": ["allow", "block"],
      "description": "Action for tools no rule matches. Omit in override layers to inherit."
    },
    "tools": {
      "type": "object",
      "description": "Tool name or glob pattern (fnmatch: * ? [seq]) → rule. Exact names beat globs; more-specific globs beat less-specific.",
      "additionalProperties": { "$ref": "#/$defs/rule" }
    },
    "taint_sources": {
      "type": "array", "items": { "type": "string" },
      "description": "Tools (glob ok) that ingest untrusted content; calling one taints the session."
    },
    "taint_sinks": {
      "type": "array", "items": { "type": "string" },
      "description": "Tools (glob ok) blocked once the session is tainted (outbound/mutating)."
    },
    "sequence_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["after", "forbid"],
        "properties": {
          "after": { "type": "string", "description": "once a tool matching this has run..." },
          "forbid": { "type": "string", "description": "...a tool matching this is blocked for the session" },
          "reason": { "type": "string" }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weights": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "risk event name → points (overrides defaults)"
        },
        "elevated_at": { "type": "integer", "default": 50 },
        "suspend_at": { "type": "integer", "default": 80 }
      }
    },
    "on_failure": {
      "description": "What happens on UNEXPECTED runtime errors (not policy denials or config errors, which always enforce). Default fail-closed. A global mode, or per-category. AT YOUR OWN RISK.",
      "oneOf": [
        { "enum": ["closed", "open"], "description": "global posture" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default": { "enum": ["closed", "open"], "default": "closed" },
            "pipeline": { "enum": ["closed", "open"], "description": "a request-stage plugin crashed" },
            "redaction": { "enum": ["closed", "open"], "description": "a detector crashed / payload over budget" },
            "approval": { "enum": ["closed", "open"], "description": "the approver was unreachable / timed out" }
          }
        }
      ]
    }
  },
  "$defs": {
    "action": {
      "enum": ["allow", "block", "redact", "rewrite", "quarantine", "require_approval"]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": { "$ref": "#/$defs/action" },
        "reason": { "type": "string" },
        "then": {
          "$ref": "#/$defs/action",
          "description": "For require_approval: the action applied once a human approves. Default allow."
        },
        "replace": {
          "type": "boolean",
          "description": "In an override layer: discard lower layers' fields for this pattern instead of field-merging."
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" }
        },
        "rewrites": {
          "type": "array",
          "items": { "$ref": "#/$defs/rewrite" }
        },
        "redaction": { "$ref": "#/$defs/redaction" },
        "roles": {
          "type": "object",
          "description": "Per-role overlay: replaces only the fields it names for callers with that role.",
          "additionalProperties": { "$ref": "#/$defs/overlay" }
        }
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": { "$ref": "#/$defs/action" },
        "reason": { "type": "string" },
        "then": { "$ref": "#/$defs/action" },
        "constraints": { "type": "array", "items": { "$ref": "#/$defs/constraint" } },
        "rewrites": { "type": "array", "items": { "$ref": "#/$defs/rewrite" } },
        "redaction": { "$ref": "#/$defs/redaction" }
      }
    },
    "redaction": {
      "description": "Redaction config for the redact action: a profile name, or a mapping refining one.",
      "oneOf": [
        { "type": "string", "description": "profile name (secrets-only | standard | strict)" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "profile": { "type": "string", "default": "standard" },
            "exclude_keys": {
              "type": "array", "items": { "type": "string" },
              "description": "never redact values under keys with these names"
            },
            "allowlist": {
              "type": "array", "items": { "type": "string" },
              "description": "literal strings never treated as sensitive"
            },
            "denylist": {
              "type": "array", "items": { "type": "string" },
              "description": "literal strings always redacted"
            },
            "context_words": {
              "type": "array", "items": { "type": "string" },
              "description": "words that, appearing just before a detection, raise its confidence over the threshold"
            }
          }
        }
      ]
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arg"],
      "anyOf": [
        { "required": ["must_match"] },
        { "required": ["must_not_match"] }
      ],
      "properties": {
        "type": { "const": "regex", "default": "regex" },
        "arg": { "type": "string", "minLength": 1 },
        "must_match": { "type": "string", "format": "regex" },
        "must_not_match": { "type": "string", "format": "regex" },
        "flags": { "enum": ["", "i"] },
        "reason": { "type": "string" }
      }
    },
    "rewrite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arg"],
      "oneOf": [
        { "required": ["set"], "not": { "required": ["append"] } },
        { "required": ["append"], "not": { "required": ["set"] } }
      ],
      "properties": {
        "arg": { "type": "string", "minLength": 1 },
        "set": { "description": "Force the argument to this fixed value." },
        "append": {
          "type": "string",
          "description": "Append to a string argument, unless unless_match already matches."
        },
        "unless_match": { "type": "string", "format": "regex" },
        "flags": { "enum": ["", "i"] }
      }
    }
  }
}
